# Gpyro property estimation program makefile - based on old NIST FDS Makefile
#
# To compile with the Intel compiler under linux, type: 
# make intel_linux
#
# To compile with the gfortran (gnu) compiler, type: 
# make gnu_linux

# The variable VPATH defines where the source code is relative to the current 
# directory

VPATH = ../../../src/common ../../../src/gpyro

ifeq ($(shell echo "check_quotes"),"check_quotes")
# windows
  GIT_HASH := $(shell ..\Scripts\githash)
  GIT_STAT := $(shell ..\Scripts\gitstat)
  GIT_DATE := $(shell ..\Scripts\gitlog)
  GIT_BRANCH := $(shell ..\Scripts\gitbranch)
  BUILD_DATE := $(shell date /t) $(shell time /t)
else
# linux/osx
  shell:=/bin/bash
  GIT_HASH := $(shell git describe --long --abbrev=7)
  ifeq ("$(shell git diff --shortstat $(VPATH)/*.f90)","")
    GIT_STAT :=
  else
    GIT_STAT := -dirty
  endif
  GIT_DATE := $(shell git log -1 --format=%cd)
  GIT_BRANCH := $(shell git rev-parse --abbrev-ref HEAD)
  BUILD_DATE := $(shell date "+%b %d, %Y  %T")
# The preprocessor used by xlf uses comma as separation between preprocessing commands.
# Commas needs to be escaped if they are to be used as part of a value in a preprocessing variable.
  BUILD_DATE_XLF := $(shell date "+%b %d\, %Y  %T")
endif

GITINFO_BASE=-DGITHASH_PP=\"$(GIT_HASH)$(GIT_STAT)-$(GIT_BRANCH)\" -DGITDATE_PP=\""$(GIT_DATE)\""
GITINFO=-fpp $(GITINFO_BASE) -DBUILDDATE_PP=\""$(BUILD_DATE)\""
GITINFOGNU=-cpp $(GITINFO_BASE) -DBUILDDATE_PP=\""$(BUILD_DATE)\""
GITINFOXLF=-qsuffix=cpp=f90 '-WF,-DGITHASH_PP=\"$(GIT_HASH)\",-DGITDATE_PP=\"$(GIT_DATE)\",-DBUILDDATE_PP=\"$(BUILD_DATE_XLF)\"'
GITINFOPGI=-Mpreprocess $(GITINFO_BASE) -DBUILDDATE_PP=\""$(BUILD_DATE)\""
# Definition of object variables


obj_serial = gpyro_prec.o gpyro_vars.o gpyro_funcs.o gpyro_mass.o gpyro_gas.o gpyro_thermal.o gpyro_bc.o gpyro_io.o\
             gpyro_pyro.o gpyro_init.o gpyro_main.o
             

objwin_serial = $(obj_serial:.o=.obj)

#*** General Purpose Rules ***

no_target:
	@echo \******** You did not specify a make target \********
	@echo Please read the comments at the top of the makefile

setup:
%.o : %.mod

setup_win:
%.obj : %.mod

.SUFFIXES: .f90 .o .obj

.f90.o:
	$(FCOMPL) -c $(FFLAGS) $<
.f90.obj:
	$(FCOMPL) -c $(FFLAGS) $<

gpyro_funcs.o: FFLAGS += $(FOPENMPFLAGS)
gpyro_vars.o : FFLAGS += $(FOPENMPFLAGS)
gpyro_pyro.o : FFLAGS += $(FOPENMPFLAGS)
gpyro_bc.o   : FFLAGS += $(FOPENMPFLAGS)
gpyro_io.o   : FFLAGS += $(FOPENMPFLAGS)
gpyro_mass.o : FFLAGS += $(FOPENMPFLAGS)
gpyro_thermal.o: FFLAGS += $(FOPENMPFLAGS)
gpyro_gas.o: FFLAGS += $(FOPENMPFLAGS)

gpyro_funcs.obj : FFLAGS += $(FOPENMPFLAGS)
gpyro_vars.obj  : FFLAGS += $(FOPENMPFLAGS)
gpyro_pyro.obj  : FFLAGS += $(FOPENMPFLAGS)
gpyro_bc.obj    : FFLAGS += $(FOPENMPFLAGS)
gpyro_io.obj    : FFLAGS += $(FOPENMPFLAGS)
gpyro_mass.obj  : FFLAGS += $(FOPENMPFLAGS)
gpyro_thermal.obj  : FFLAGS += $(FOPENMPFLAGS)
gpyro_gas.obj  : FFLAGS += $(FOPENMPFLAGS)

gpyro_main.o    : FFLAGS +=$(GITINFOGNU)
gpyro_io.o      : FFLAGS +=$(GITINFOGNU)
gpyro_main.obj  : FFLAGS +=$(GITINFOGNU)
gpyro_io.obj    : FFLAGS +=$(GITINFOGNU)

# Intel compiler:


intel_linux : FFLAGS = -O2 -ip -unroll -xHost -qopt-report=5 -frecord-marker=4 -ffree-line-length-none
intel_linux : FCOMPL = $(GPYRO_FCOMPL_INTEL)
intel_linux : FOPENMPFLAGS = -qopenmp -liomp5
intel_linux : obj = gpyro
intel_linux : setup $(obj_serial)
	$(FCOMPL) $(FFLAGS) $(FOPENMPFLAGS) -o $(obj) $(obj_serial)


intel_linux_debug : FFLAGS = -O0 -g -traceback -check all -debug all -fpe0 -warn all -frecord-marker=4 -ffree-line-length-none
intel_linux_debug : FCOMPL = $(GPYRO_FCOMPL_INTEL)
intel_linux_debug : obj = gpyro_debug
intel_linux_debug : setup $(obj_serial)
	$(FCOMPL) $(FFLAGS) -o $(obj) $(obj_serial)



#Gnu compiler:

gnu_linux : FFLAGS = -O2 -unroll -frecord-marker=4 -ffree-line-length-none
gnu_linux : FCOMPL = $(GPYRO_FCOMPL_GNU)
gnu_linux : obj = gpyro
gnu_linux : FOPENMPFLAGS = -fopenmp
gnu_linux : setup $(obj_serial)
	$(FCOMPL) $(FFLAGS) $(FOPENMPFLAGS) -o $(obj) $(obj_serial)

gnu_linux_debug : FFLAGS = -O0 -g -Wall -fcheck=all -fbacktrace -ffpe-trap=invalid,zero -fdump-core  -frecord-marker=4 -ffree-line-length-none
gnu_linux_debug : FCOMPL = $(GPYRO_FCOMPL_GNU)
gnu_linux_debug : obj = gpyro_debug
gnu_linux_debug : setup $(obj_serial)
	$(FCOMPL) $(FFLAGS) -o $(obj) $(obj_serial)

gnu_win : FFLAGS = -O2 -unroll -frecord-marker=4 -ffree-line-length-none
gnu_win : FCOMPL = gfortran
gnu_win : obj = gpyro
gnu_win : setup $(obj_serial)
	$(FCOMPL) $(FFLAGS) -o $(obj) $(obj_serial)

#*** End Compiler Specific Rules ***

